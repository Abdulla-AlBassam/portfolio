---
type Category = "cybersecurity" | "networking" | "development" | "ml";

interface Props {
  category: Category;
  class?: string;
}

const { category, class: className = "" } = Astro.props;
---

<svg
  class:list={["cat-icon", `cat-${category}`, className]}
  width="13"
  height="13"
  viewBox="0 0 16 16"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {category === "development" && (
    <>
      <polyline points="6 4 2 8 6 12" />
      <polyline points="10 4 14 8 10 12" />
    </>
  )}
  {category === "cybersecurity" && (
    <path d="M 8 2 L 2.75 4 V 8 C 2.75 11 5.25 13.5 8 14 C 10.75 13.5 13.25 11 13.25 8 V 4 Z" />
  )}
  {category === "ml" && (
    <path d="M 8 2 L 9.1 6.9 L 14 8 L 9.1 9.1 L 8 14 L 6.9 9.1 L 2 8 L 6.9 6.9 Z" />
  )}
  {category === "networking" && (
    <>
      <circle cx="8" cy="3.5" r="1.5" />
      <circle cx="3.5" cy="12.5" r="1.5" />
      <circle cx="12.5" cy="12.5" r="1.5" />
      <line x1="7.3" y1="4.9" x2="4.2" y2="11.1" />
      <line x1="8.7" y1="4.9" x2="11.8" y2="11.1" />
      <line x1="5" y1="12.5" x2="11" y2="12.5" />
    </>
  )}
</svg>
