---
import MinimalLayout from "@/layouts/MinimalLayout.astro";

type Category = "cybersecurity" | "networking" | "development" | "ml";

interface Project {
  title: string;
  year: string;
  href?: string;
  external?: boolean;
  inProgress?: boolean;
  categories: Category[];
  modal?: string;
}

const projects: Project[] = [
  {
    title: "This Portfolio",
    year: "2026",
    href: "https://github.com/Abdulla-AlBassam/Portfolio",
    external: true,
    categories: ["development"],
  },
  {
    title: "Local Email Server with a Cascade AI Spam Filter",
    year: "2026",
    categories: ["ml", "cybersecurity"],
    modal: "email-server",
  },
  {
    title: "Sweaty: Social Gaming Platform",
    year: "2025 — present",
    href: "https://www.linkedin.com/in/abdulla-albassam/overlay/experience/2864877680/multiple-media-viewer/?profileId=ACoAAF0wWosB-M5smshM0TcBM7F127DOES9M6N8&treasuryMediaId=1773201904530",
    external: true,
    inProgress: true,
    categories: ["development"],
  },
  {
    title: "Penetration Testing: Vulnerable VM",
    year: "2026",
    categories: ["cybersecurity"],
  },
  {
    title: "Cryptographic Transaction Protocol Design",
    year: "2026",
    categories: ["cybersecurity"],
  },
  {
    title: "Enterprise Networking: Segmented WAN with Selective IPsec",
    year: "2025",
    href: "/projects/docs/enterprise-wan.pdf",
    external: true,
    categories: ["networking"],
  },
  {
    title: "Digital Forensics: Timeline Reconstruction",
    year: "2025",
    href: "/projects/docs/digital-forensics.pdf",
    external: true,
    categories: ["cybersecurity"],
  },
  {
    title: "Client Audit + Security Assessment Report",
    year: "2025",
    categories: ["cybersecurity"],
  },
  {
    title: "Networking: Secure VLAN Routing + Layer-2 Hardening",
    year: "2024",
    href: "/projects/docs/secure-vlan.pdf",
    external: true,
    categories: ["networking"],
  },
  {
    title: "Qualitative Study: Young-Adult Security Literacy",
    year: "2024",
    href: "/projects/docs/qualitative-study.pdf",
    external: true,
    categories: ["cybersecurity"],
  },
  {
    title: "REST API Build + Architecture Blueprint",
    year: "2024",
    href: "/showcase/projects/rest-api",
    categories: ["development", "cybersecurity"],
  },
  {
    title: "Operating Systems: Concurrent C + HA DNS/Web Infrastructure",
    year: "2024",
    href: "/showcase/projects/operating-systems",
    categories: ["development", "networking"],
  },
].sort((a, b) => sortKey(b.year) - sortKey(a.year));

function sortKey(year: string): number {
  // "present" or "current" entries always sort to the top
  if (/present|current/i.test(year)) return 9999;
  // Pick the latest 4-digit year mentioned in the string
  const matches = year.match(/\d{4}/g);
  return matches ? Math.max(...matches.map(Number)) : 0;
}

const filters = [
  { id: "all", label: "All" },
  { id: "cybersecurity", label: "Cybersecurity" },
  { id: "networking", label: "Networking" },
  { id: "development", label: "Development" },
  { id: "ml", label: "Machine Learning" },
];
---

<MinimalLayout title="Projects — Abdulla AlBassam" active="projects">
  <img slot="sidebar-extra" src="/cat.webp" alt="" class="sidebar-cartoon" />
  <section class="projects">
    <div class="filter-bar" role="tablist" aria-label="Filter projects by category">
      {
        filters.map((f) => (
          <button
            class:list={["filter", { active: f.id === "all" }]}
            data-filter={f.id}
            type="button"
            role="tab"
            aria-selected={f.id === "all" ? "true" : "false"}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <ul class="project-list">
      {
        projects.map((p) => {
          const dataCats = [
            ...p.categories,
            ...(p.inProgress ? ["in-progress"] : []),
          ].join(" ");
          const Tag = p.modal ? "button" : p.href ? "a" : "div";
          const tagProps = p.modal
            ? { type: "button", "data-modal-trigger": p.modal }
            : p.href
            ? p.external
              ? { href: p.href, target: "_blank", rel: "noopener noreferrer" }
              : { href: p.href }
            : {};
          return (
            <li class="project-item" data-categories={dataCats}>
              <Tag class="project-row" {...tagProps}>
                <span class="project-title">{p.title}</span>
                <span class="project-meta">
                  <span class="project-year">{p.year}</span>
                  {p.inProgress && (
                    <>
                      <span class="meta-sep" aria-hidden="true">·</span>
                      <span class="in-progress">In progress</span>
                    </>
                  )}
                </span>
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </section>

  <dialog class="link-modal" id="email-server-modal" aria-labelledby="email-server-modal-title">
    <button type="button" class="modal-close" aria-label="Close" data-modal-close>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <p class="modal-eyebrow">View project</p>
    <h3 class="modal-title" id="email-server-modal-title">Local Email Server with a Cascade AI Spam Filter</h3>
    <p class="modal-sub">Dissertation project — hardened SMTP/IMAP stack with multi-stage AI filtering</p>
    <div class="modal-actions">
      <a href="/projects/docs/dissertation.pdf" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
        </svg>
        <span class="label">Thesis</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a href="https://github.com/Abdulla-AlBassam" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-1.97c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z" />
        </svg>
        <span class="label">GitHub</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </dialog>
</MinimalLayout>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter");
  const items = document.querySelectorAll<HTMLLIElement>(".project-item");

  filterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.filter || "all";
      filterButtons.forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle("active", isActive);
        b.setAttribute("aria-selected", isActive ? "true" : "false");
      });
      items.forEach((item) => {
        const cats = (item.dataset.categories || "").split(" ");
        const show = target === "all" || cats.includes(target);
        (item as HTMLElement).style.display = show ? "" : "none";
      });
    });
  });

  document.querySelectorAll<HTMLElement>('[data-modal-trigger]').forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const id = trigger.getAttribute("data-modal-trigger");
      const dialog = document.getElementById(`${id}-modal`) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  document.querySelectorAll<HTMLDialogElement>("dialog.link-modal").forEach((dialog) => {
    dialog.querySelector<HTMLButtonElement>("[data-modal-close]")?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .projects {
    color: var(--ink-soft);
  }

  .lede {
    color: var(--cloudy-deep);
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0 0 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--rule);
  }

  .filter {
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--cloudy-deep);
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .filter:hover {
    color: var(--ink);
    border-color: var(--cloudy);
  }

  .filter.active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--pampas);
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-item {
    border-bottom: 1px solid var(--rule);
  }

  .project-item:last-child {
    border-bottom: none;
  }

  .project-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.8rem 0;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a.project-row:hover,
  button.project-row:hover {
    color: var(--crail);
  }

  a.project-row:hover .project-year,
  button.project-row:hover .project-year {
    color: var(--crail);
  }

  button.project-row {
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
    font: inherit;
  }

  .project-title {
    font-family: "Montserrat", sans-serif;
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .project-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    white-space: nowrap;
  }

  .project-year {
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--cloudy-deep);
    transition: color 0.15s ease;
  }

  .meta-sep {
    color: var(--cloudy);
    font-size: 0.72rem;
  }

  .in-progress {
    font-family: "Montserrat", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--crail);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  div.project-row {
    cursor: default;
  }

  @media (max-width: 600px) {
    .project-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }

  /* Modal styles (mirrors index.astro) */
  .link-modal {
    background: var(--pampas);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1.75rem 1.75rem 1.5rem;
    width: min(92vw, 420px);
    box-shadow: 0 30px 80px rgba(20, 18, 16, 0.28), 0 2px 8px rgba(20, 18, 16, 0.08);
    position: relative;
    font-family: "Montserrat", sans-serif;
  }

  .link-modal::backdrop {
    background: rgba(26, 24, 22, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .link-modal[open] {
    animation: modal-in 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .link-modal[open]::backdrop {
    animation: backdrop-in 0.2s ease-out;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.96) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .modal-close {
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--cloudy-deep);
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .modal-close:hover {
    color: var(--ink);
    background: var(--pampas-deep);
  }

  .modal-eyebrow {
    font-family: "Montserrat", sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 0 0 0.55rem;
  }

  .modal-title {
    font-family: "Montserrat", sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
    color: var(--ink);
    line-height: 1.3;
  }

  .modal-sub {
    font-size: 0.78rem;
    color: var(--cloudy-deep);
    margin: 0 0 1.25rem;
  }

  .modal-actions {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .modal-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.95rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    color: var(--ink);
    text-decoration: none;
    font-family: "Montserrat", sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    background: transparent;
    transition: 0.18s ease;
  }

  .modal-btn .icon,
  .modal-btn .arrow {
    flex-shrink: 0;
    color: var(--ink-soft);
    transition: color 0.18s ease, transform 0.18s ease;
  }

  .modal-btn .label {
    flex: 1;
  }

  .modal-btn .arrow {
    color: var(--cloudy-deep);
  }

  .modal-btn:hover {
    background: var(--crail);
    color: var(--pampas);
    border-color: var(--crail);
  }

  .modal-btn:hover .icon,
  .modal-btn:hover .arrow {
    color: var(--pampas);
  }

  .modal-btn:hover .arrow {
    transform: translateX(3px);
  }

  .modal-btn:focus-visible {
    outline: 2px solid var(--crail);
    outline-offset: 2px;
  }
</style>
