---
import MinimalLayout from "@/layouts/MinimalLayout.astro";
import LinkModal from "@/components/LinkModal.astro";

type Category = "cybersecurity" | "networking" | "development" | "ml";

interface Project {
  title: string;
  year: string;
  href?: string;
  external?: boolean;
  inProgress?: boolean;
  categories: Category[];
  modal?: string;
}

const projects: Project[] = [
  {
    title: "This Portfolio",
    year: "2026",
    categories: ["development"],
    modal: "portfolio",
  },
  {
    title: "Mane: Native macOS Ad Blocker",
    year: "2026 – present",
    inProgress: true,
    href: "https://github.com/Abdulla-AlBassam/mane",
    external: true,
    categories: ["development", "cybersecurity"],
  },
  {
    title: "URL Triage Agent: Autonomous Phishing Investigator",
    year: "2026",
    href: "https://github.com/Abdulla-AlBassam/url-triage-agent",
    external: true,
    categories: ["cybersecurity", "ml"],
  },
  {
    title: "Local Email Server with a Cascade AI Spam Filter",
    year: "2026",
    categories: ["ml", "cybersecurity"],
    modal: "email-server",
  },
  {
    title: "Sweaty: Social Gaming Platform",
    year: "2025 – present",
    inProgress: true,
    categories: ["development"],
    modal: "sweaty",
  },
  {
    title: "Penetration Testing: Vulnerable VM",
    year: "2026",
    categories: ["cybersecurity"],
  },
  {
    title: "Cyb: Gamified Cybersecurity Learning Platform",
    year: "2025",
    href: "https://github.com/Abdulla-AlBassam/cyb",
    external: true,
    categories: ["cybersecurity", "development"],
  },
  {
    title: "Cryptographic Transaction Protocol Design",
    year: "2026",
    href: "/projects/docs/cryptographic-protocol.pdf",
    external: true,
    categories: ["cybersecurity"],
  },
  {
    title: "Enterprise Networking: Segmented WAN with Selective IPsec",
    year: "2025",
    href: "/projects/docs/enterprise-wan.pdf",
    external: true,
    categories: ["networking"],
  },
  {
    title: "Digital Forensics: Timeline Reconstruction",
    year: "2025",
    href: "/projects/docs/digital-forensics.pdf",
    external: true,
    categories: ["cybersecurity"],
  },
  {
    title: "Client Audit + Security Assessment Report",
    year: "2025",
    categories: ["cybersecurity"],
  },
  {
    title: "Networking: Secure VLAN Routing + Layer-2 Hardening",
    year: "2024",
    href: "/projects/docs/secure-vlan.pdf",
    external: true,
    categories: ["networking"],
  },
  {
    title: "Qualitative Study: Young-Adult Security Literacy",
    year: "2024",
    href: "/projects/docs/qualitative-study.pdf",
    external: true,
    categories: ["cybersecurity"],
  },
].sort((a, b) => sortKey(b.year) - sortKey(a.year));

function sortKey(year: string): number {
  if (/present|current/i.test(year)) return 9999;
  const matches = year.match(/\d{4}/g);
  return matches ? Math.max(...matches.map(Number)) : 0;
}

const filters = [
  { id: "all", label: "All" },
  { id: "cybersecurity", label: "Cybersecurity" },
  { id: "networking", label: "Networking" },
  { id: "development", label: "Development" },
  { id: "ml", label: "Machine Learning" },
];
---

<MinimalLayout title="Projects – Abdulla AlBassam" active="projects">
  <img slot="sidebar-extra" src="/cat.webp" alt="" class="sidebar-cartoon" />
  <section class="projects">
    <div class="filter-bar" role="tablist" aria-label="Filter projects by category">
      {
        filters.map((f) => (
          <button
            class:list={["filter", { active: f.id === "all" }]}
            data-filter={f.id}
            type="button"
            role="tab"
            aria-selected={f.id === "all" ? "true" : "false"}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <ul class="project-list">
      {
        projects.map((p) => {
          const dataCats = [
            ...p.categories,
            ...(p.inProgress ? ["in-progress"] : []),
          ].join(" ");
          const Tag = p.modal ? "button" : p.href ? "a" : "div";
          const tagProps = p.modal
            ? { type: "button", "data-modal-trigger": p.modal }
            : p.href
            ? p.external
              ? { href: p.href, target: "_blank", rel: "noopener noreferrer" }
              : { href: p.href }
            : {};
          return (
            <li class="project-item" data-categories={dataCats}>
              <Tag class="project-row" {...tagProps}>
                <span class="project-title">{p.title}</span>
                <span class="project-meta">
                  <span class="project-year">{p.year}</span>
                  {p.inProgress && (
                    <>
                      <span class="meta-sep" aria-hidden="true">·</span>
                      <span class="in-progress">In progress</span>
                    </>
                  )}
                </span>
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </section>

  <LinkModal
    id="portfolio"
    eyebrow="View project"
    title="This Portfolio"
    subtitle="Astro static site on Vercel, self-assessed for security"
    links={[
      { label: "GitHub", href: "https://github.com/Abdulla-AlBassam/Portfolio", icon: "github" },
      { label: "Vulnerability Assessment", href: "/projects/docs/vulnerability-assessment.pdf", icon: "pdf" },
    ]}
  />

  <LinkModal
    id="email-server"
    eyebrow="View project"
    title="Local Email Server with a Cascade AI Spam Filter"
    subtitle="Dissertation project: hardened SMTP/IMAP stack with multi-stage AI filtering"
    links={[
      { label: "Thesis", href: "/projects/docs/dissertation.pdf", icon: "pdf" },
      { label: "GitHub", href: "https://github.com/Abdulla-AlBassam/mini-mail", icon: "github" },
    ]}
  />

  <LinkModal
    id="sweaty"
    eyebrow="View project"
    title="Sweaty"
    subtitle="A social platform for gamers · in active development"
    links={[
      { label: "sweatyapp.com", href: "https://sweatyapp.com", icon: "globe" },
      { label: "LinkedIn", href: "https://www.linkedin.com/in/abdulla-albassam/overlay/experience/2864877680/multiple-media-viewer/?profileId=ACoAAF0wWosB-M5smshM0TcBM7F127DOES9M6N8&treasuryMediaId=1773201904530", icon: "linkedin" },
      { label: "X / Twitter", href: "https://x.com/sweatyapp", icon: "twitter" },
    ]}
  />
</MinimalLayout>

<style is:global>
  body:has(.projects) .sidebar-cartoon {
    transform: translateX(-1rem);
  }
</style>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter");
  const items = document.querySelectorAll<HTMLLIElement>(".project-item");

  filterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.filter || "all";
      filterButtons.forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle("active", isActive);
        b.setAttribute("aria-selected", isActive ? "true" : "false");
      });
      items.forEach((item) => {
        const cats = (item.dataset.categories || "").split(" ");
        const show = target === "all" || cats.includes(target);
        (item as HTMLElement).style.display = show ? "" : "none";
      });
    });
  });
</script>

<style>
  .projects {
    color: var(--ink-soft);
  }

  .lede {
    color: var(--cloudy-deep);
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0 0 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--rule);
  }

  .filter {
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--cloudy-deep);
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .filter:hover {
    color: var(--ink);
    border-color: var(--cloudy);
  }

  .filter.active {
    background: var(--crail);
    border-color: var(--crail);
    color: var(--pampas);
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-item {
    border-bottom: 1px solid var(--rule);
  }

  .project-item:last-child {
    border-bottom: none;
  }

  .project-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.8rem 0;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a.project-row:hover,
  button.project-row:hover {
    color: var(--crail);
  }

  a.project-row:hover .project-year,
  button.project-row:hover .project-year {
    color: var(--crail);
  }

  button.project-row {
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
    font: inherit;
  }

  .project-title {
    font-family: "Montserrat", sans-serif;
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .project-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    white-space: nowrap;
  }

  .project-year {
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--cloudy-deep);
    transition: color 0.15s ease;
  }

  .meta-sep {
    color: var(--cloudy);
    font-size: 0.72rem;
  }

  .in-progress {
    font-family: "Montserrat", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--crail);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  div.project-row {
    cursor: default;
  }

  @media (max-width: 600px) {
    .project-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }
</style>
