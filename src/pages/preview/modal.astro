---
import MinimalLayout from "@/layouts/MinimalLayout.astro";

const variants = [
  { id: "a-goo",     glass: "glass-a", entry: "entry-goo",     code: "A1", desc: "Pure refraction · Goo morph" },
  { id: "a-droplet", glass: "glass-a", entry: "entry-droplet", code: "A2", desc: "Pure refraction · Droplet" },
  { id: "b-goo",     glass: "glass-b", entry: "entry-goo",     code: "B1", desc: "Refraction + bevels · Goo morph" },
  { id: "b-droplet", glass: "glass-b", entry: "entry-droplet", code: "B2", desc: "Refraction + bevels · Droplet" },
  { id: "c-goo",     glass: "glass-c", entry: "entry-goo",     code: "C1", desc: "Tinted refraction · Goo morph" },
  { id: "c-droplet", glass: "glass-c", entry: "entry-droplet", code: "C2", desc: "Tinted refraction · Droplet" },
  { id: "d-goo",     glass: "glass-d", entry: "entry-goo",     code: "D1", desc: "Frosted (no refraction) · Goo morph" },
  { id: "d-droplet", glass: "glass-d", entry: "entry-droplet", code: "D2", desc: "Frosted (no refraction) · Droplet" },
];
---

<MinimalLayout title="Glass modal preview" active="about">
  <img
    slot="sidebar-extra"
    src="/cartoon.webp"
    alt=""
    class="sidebar-cartoon"
    width="220"
    height="220"
    loading="eager"
    decoding="async"
  />

  {/* Realistic underlay — mirrors the About page so the modal sits on real-feeling content. */}
  <section class="about">
    <img
      src="/cartoon-about-formal.webp"
      alt=""
      class="cartoon cartoon-right"
      width="220"
      height="275"
      loading="eager"
      decoding="async"
    />
    <p>
      I'm a final-year Cybersecurity and Networking student at Northumbria University,
      on track for First Class Honours and a recipient of the Emdad Scholarship.
    </p>
    <p>
      My recently completed dissertation built a
      <strong>hardened email system with a cascading AI filter</strong>,
      sharpening my interest in agentic and autonomous AI, and how they will
      reshape both sides of the cyber arms race.
    </p>
    <p>
      I'm also building Sweaty, a social platform for gamers.
    </p>
    <p>
      Recently, my team and I took home the Innovation Award at Northumbria's
      Anthropic × Accenture Hackathon, where we built a digital solution to a
      problem affecting the people of the UK.
    </p>
    <p>
      On the offensive, I specialise in web and SQL exploitation, and I'm
      currently working toward the eJPT certification. On the defensive, I have
      hands-on experience in intrusion detection, network hardening, and digital forensics.
    </p>
    <h2 class="block-heading">Education</h2>
    <ul class="entries">
      <li>
        <div class="entry-row">
          <div><strong>BSc (Hons) Networks &amp; Cyber Security</strong><span class="muted"> · Northumbria University</span></div>
          <span class="meta">2023 — 2026</span>
        </div>
        <p class="muted small">Predicted: First Class Honours.</p>
      </li>
      <li>
        <div class="entry-row">
          <div><strong>Foundation Year: Economics &amp; Mathematics</strong><span class="muted"> · King's College London</span></div>
          <span class="meta">2022 — 2023</span>
        </div>
        <p class="muted small">Grade: 2:1.</p>
      </li>
      <li>
        <div class="entry-row">
          <div><strong>American Diploma with Honours</strong><span class="muted"> · Modern Knowledge Schools, Bahrain</span></div>
          <span class="meta">2008 — 2022</span>
        </div>
        <p class="muted small">Grade: 98%</p>
      </li>
    </ul>
  </section>

  {/* SVG filter defs — defined inline so the preview is fully self-contained. */}
  <svg class="filter-defs" aria-hidden="true" focusable="false">
    <defs>
      <filter id="liquid-glass" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.012 0.012" numOctaves="2" seed="3" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="22" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
      <filter id="liquid-glass-strong" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.009 0.009" numOctaves="2" seed="5" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="36" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
    </defs>
  </svg>

  {/* Floating variant picker — always visible, switches modal in place. */}
  <aside class="picker" aria-label="Variant picker">
    <p class="picker-title">Glass modal preview</p>
    <p class="picker-sub">Click any row to open. The picker stays on top so you can flick between variants.</p>
    <ul class="picker-list">
      {variants.map((v) => (
        <li>
          <button
            type="button"
            class="picker-btn"
            data-variant
            data-glass={v.glass}
            data-entry={v.entry}
          >
            <span class="picker-code">{v.code}</span>
            <span class="picker-desc">{v.desc}</span>
          </button>
        </li>
      ))}
    </ul>
    <button type="button" class="picker-close" data-modal-close-shortcut>Close modal (Esc)</button>
  </aside>

  {/* Single shared modal — variant classes are swapped on each open. */}
  <dialog class="liquid-modal" id="preview-modal" aria-labelledby="preview-modal-title">
    <button type="button" class="modal-close" aria-label="Close" data-modal-close>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <p class="modal-eyebrow">View project</p>
    <h3 class="modal-title" id="preview-modal-title">Lean-in</h3>
    <p class="modal-sub">Anthropic × Accenture Hackathon · Innovation Award</p>
    <div class="modal-actions">
      <a href="https://github.com/Abdulla-AlBassam/lean-in" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-1.97c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
        <span class="label">GitHub</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="https://www.linkedin.com/feed/update/urn:li:activity:7459351820537274368/" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
        <span class="label">LinkedIn</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
    <figure class="modal-cert">
      <img src="/certs/hackathon.webp" alt="Certificate of Achievement — Accenture Award for Innovation" loading="lazy" />
    </figure>
  </dialog>

  <script>
    const dialog = document.getElementById('preview-modal') as HTMLDialogElement | null;
    const GLASS_CLASSES = ['glass-a', 'glass-b', 'glass-c', 'glass-d'];
    const ENTRY_CLASSES = ['entry-goo', 'entry-droplet'];

    const applyVariant = (glass: string, entry: string) => {
      if (!dialog) return;
      GLASS_CLASSES.forEach((c) => dialog.classList.remove(c));
      ENTRY_CLASSES.forEach((c) => dialog.classList.remove(c));
      // Force reflow so re-adding the entry class restarts the animation.
      void dialog.offsetWidth;
      dialog.classList.add(glass, entry);
    };

    document.querySelectorAll<HTMLButtonElement>('[data-variant]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const glass = btn.dataset.glass || 'glass-d';
        const entry = btn.dataset.entry || 'entry-goo';
        document.querySelectorAll('[data-variant]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        if (dialog?.open) {
          // Re-trigger entrance with new variant.
          dialog.classList.remove(...ENTRY_CLASSES);
          void dialog.offsetWidth;
          applyVariant(glass, entry);
        } else {
          applyVariant(glass, entry);
          dialog?.showModal();
        }
      });
    });

    dialog?.querySelector<HTMLButtonElement>('[data-modal-close]')?.addEventListener('click', () => dialog.close());
    dialog?.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
    document.querySelector<HTMLButtonElement>('[data-modal-close-shortcut]')?.addEventListener('click', () => dialog?.close());
  </script>
</MinimalLayout>

<style>
  /* ============ Underlay content (cribbed from /) ============ */
  .about { color: var(--ink-soft); font-size: 0.95rem; line-height: 1.65; position: relative; }
  .cartoon-right { position: absolute; top: -0.5rem; left: 100%; margin-left: 2rem; width: 220px; height: auto; pointer-events: none; user-select: none; }
  @media (max-width: 1080px) { .cartoon-right { display: none; } }
  .about strong { color: var(--ink); font-weight: 600; }
  .block-heading { font-family: "Montserrat", sans-serif; font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--cloudy-deep); margin: 2.5rem 0 1rem; }
  .entries { list-style: none; padding: 0; margin: 0; }
  .entries > li { padding: 0.7rem 0; border-bottom: 1px solid var(--rule); }
  .entries > li:last-child { border-bottom: none; }
  .entry-row { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .entry-row strong { color: var(--ink); font-weight: 600; }
  .meta { font-family: "Montserrat", sans-serif; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.06em; color: var(--cloudy-deep); white-space: nowrap; }
  .muted { color: var(--cloudy-deep); }
  .small { font-size: 0.8rem; margin: 0.3rem 0 0; }

  /* Hide the SVG defs container without affecting filter availability. */
  .filter-defs { position: absolute; width: 0; height: 0; pointer-events: none; }

  /* ============ Floating variant picker ============ */
  .picker {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 1000;
    width: 280px;
    background: var(--pampas);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1rem 1rem 0.75rem;
    box-shadow: 0 12px 32px rgba(20, 18, 16, 0.12);
    font-family: "Montserrat", sans-serif;
  }
  .picker-title {
    margin: 0 0 0.2rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .picker-sub {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    color: var(--cloudy-deep);
    line-height: 1.4;
  }
  .picker-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.2rem; }
  .picker-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    cursor: pointer;
    font: inherit;
    font-size: 0.78rem;
    color: var(--ink-soft);
    text-align: left;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .picker-btn:hover {
    background: var(--pampas-deep);
    color: var(--ink);
  }
  .picker-btn.active {
    border-color: var(--crail);
    color: var(--ink);
    background: rgba(193, 95, 60, 0.06);
  }
  .picker-code {
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--crail);
    flex-shrink: 0;
    width: 1.4rem;
  }
  .picker-desc { flex: 1; }
  .picker-close {
    width: 100%;
    margin-top: 0.65rem;
    padding: 0.45rem;
    background: transparent;
    border: 1px dashed var(--rule);
    border-radius: 6px;
    color: var(--cloudy-deep);
    font: inherit;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    cursor: pointer;
  }
  .picker-close:hover { color: var(--ink); border-color: var(--cloudy-deep); }

  @media (max-width: 860px) {
    .picker {
      top: auto;
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      border-radius: 10px 10px 0 0;
      border-bottom: none;
    }
  }

  /* ============ The modal (shared shell) ============ */
  .liquid-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(92vw, 380px);
    max-height: 86vh;
    overflow-y: auto;
    padding: 1.5rem 1.5rem 1.25rem;
    border: none;
    border-radius: 16px;
    color: var(--ink);
    font-family: "Montserrat", sans-serif;
    /* Strong drop-shadow makes the glass feel like a real floating layer. */
    box-shadow: 0 30px 70px rgba(20, 18, 16, 0.22), 0 4px 14px rgba(20, 18, 16, 0.08);
    will-change: transform, opacity, clip-path, border-radius, filter;
  }

  /* Barely-there dim — page stays sharp behind. NO blur. */
  .liquid-modal::backdrop {
    background: rgba(20, 18, 16, 0.05);
  }

  /* ============ Glass variants ============ */
  /* A. Pure refraction — most "Apple Liquid Glass". Falls back to a clean tint in Firefox. */
  .liquid-modal.glass-a {
    background: rgba(244, 243, 238, 0.32);
    backdrop-filter: url(#liquid-glass) saturate(1.25);
    -webkit-backdrop-filter: saturate(1.25);
    border: 1px solid rgba(255, 255, 255, 0.55);
  }

  /* B. Refraction + bevels — heavier "physical glass" look. */
  .liquid-modal.glass-b {
    background: rgba(244, 243, 238, 0.28);
    backdrop-filter: url(#liquid-glass-strong) saturate(1.3);
    -webkit-backdrop-filter: saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.35),
      inset 0 1.5px 0 0 rgba(255, 255, 255, 0.7),
      inset 0 -1px 0 0 rgba(0, 0, 0, 0.04),
      inset 8px 8px 24px -8px rgba(255, 255, 255, 0.4),
      0 30px 70px rgba(20, 18, 16, 0.22),
      0 4px 14px rgba(20, 18, 16, 0.08);
  }

  /* C. Tinted refraction — refraction + warm pampas wash so palette stays consistent. */
  .liquid-modal.glass-c {
    background: rgba(244, 243, 238, 0.58);
    backdrop-filter: url(#liquid-glass) saturate(1.18);
    -webkit-backdrop-filter: saturate(1.18);
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  /* D. Frosted clear — no refraction, just a calm glass tint. Works in every browser. */
  .liquid-modal.glass-d {
    background: rgba(244, 243, 238, 0.45);
    backdrop-filter: saturate(1.3);
    -webkit-backdrop-filter: saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.55);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.4),
      0 30px 70px rgba(20, 18, 16, 0.22),
      0 4px 14px rgba(20, 18, 16, 0.08);
  }

  /* ============ Entrance animations ============ */
  /* 1. Goo morph — starts as a small blob with blur, deforms through irregular border-radii into the final rounded square. */
  .liquid-modal.entry-goo[open] {
    animation: goo-in 0.55s cubic-bezier(0.34, 1.4, 0.5, 1) both;
  }
  @keyframes goo-in {
    0%   { opacity: 0; transform: scale(0.25); filter: blur(8px); border-radius: 50% 42% 58% 50%; }
    45%  { opacity: 1; filter: blur(3px); border-radius: 38% 50% 42% 56%; }
    75%  { filter: blur(0.5px); border-radius: 22% 18% 24% 20%; }
    100% { opacity: 1; transform: scale(1); filter: blur(0); border-radius: 16px; }
  }

  /* 2. Liquid droplet — starts as a vertical droplet shape, "splashes" wider then settles. */
  .liquid-modal.entry-droplet[open] {
    animation: droplet-in 0.6s cubic-bezier(0.22, 1.45, 0.36, 1) both;
  }
  @keyframes droplet-in {
    0%   { opacity: 0; transform: scale(0.4, 0.15) translateY(-40px); border-radius: 50% 50% 50% 50% / 80% 80% 20% 20%; filter: blur(4px); }
    35%  { opacity: 1; transform: scale(0.8, 0.65) translateY(-8px); border-radius: 50% 50% 30% 30% / 60% 60% 20% 20%; filter: blur(1.5px); }
    60%  { transform: scale(1.04, 1.06); border-radius: 30% 30% 22% 22% / 30% 30% 16% 16%; filter: blur(0.3px); }
    80%  { transform: scale(0.98, 0.99); border-radius: 18px; }
    100% { opacity: 1; transform: scale(1); border-radius: 16px; filter: blur(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .liquid-modal[open] { animation: simple-fade 0.18s ease-out both; }
    @keyframes simple-fade { from { opacity: 0; } to { opacity: 1; } }
  }

  /* ============ Modal content ============ */
  .modal-close {
    position: absolute;
    top: 0.65rem;
    right: 0.65rem;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    color: var(--cloudy-deep);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .modal-close:hover {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.4);
  }
  .modal-eyebrow {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 0 0 0.5rem;
  }
  .modal-title { font-size: 1.2rem; font-weight: 600; margin: 0 0 0.3rem; color: var(--ink); }
  .modal-sub { font-size: 0.78rem; color: var(--cloudy-deep); margin: 0 0 1.1rem; }
  .modal-actions { display: flex; flex-direction: column; gap: 0.5rem; }
  .modal-btn {
    display: flex; align-items: center; gap: 0.7rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid rgba(20, 18, 16, 0.14);
    border-radius: 8px;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.25);
    transition: 0.18s ease;
  }
  .modal-btn .icon, .modal-btn .arrow { flex-shrink: 0; color: var(--ink-soft); transition: color 0.18s ease, transform 0.18s ease; }
  .modal-btn .label { flex: 1; }
  .modal-btn .arrow { color: var(--cloudy-deep); }
  .modal-btn:hover { background: var(--ink); color: var(--pampas); border-color: var(--ink); }
  .modal-btn:hover .icon, .modal-btn:hover .arrow { color: var(--pampas); }
  .modal-btn:hover .arrow { transform: translateX(3px); }
  .modal-btn:focus-visible { outline: 2px solid var(--crail); outline-offset: 2px; }

  .modal-cert {
    margin: 1rem 0 0;
    padding: 0.4rem;
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(20, 18, 16, 0.08);
    border-radius: 8px;
  }
  .modal-cert img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
  }
</style>
