---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotographyGrid from "@/components/PhotographyGrid.svelte";

const photographyDir = path.join(process.cwd(), "public", "photography");
const thumbDir = path.join(photographyDir, "thumbs");
const midDir = path.join(photographyDir, "mid");
const validExtensions = new Set([".jpg", ".jpeg", ".png", ".webp", ".avif", ".gif"]);

let photos: { src: string; thumb: string; mid: string }[] = [];

if (fs.existsSync(photographyDir)) {
  const hasThumbDir = fs.existsSync(thumbDir);
  const hasMidDir = fs.existsSync(midDir);
  const thumbFiles = hasThumbDir ? new Set(fs.readdirSync(thumbDir)) : new Set<string>();
  const midFiles = hasMidDir ? new Set(fs.readdirSync(midDir)) : new Set<string>();

  photos = fs
    .readdirSync(photographyDir)
    .filter((file) => {
      const ext = path.extname(file).toLowerCase();
      return validExtensions.has(ext) && !file.startsWith(".");
    })
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
    .map((file) => {
      const webpName = file.replace(/\.\w+$/, ".webp");
      const hasThumb = thumbFiles.has(webpName);
      const hasMid = midFiles.has(webpName);
      return {
        src: `/photography/${file}`,
        thumb: hasThumb ? `/photography/thumbs/${webpName}` : `/photography/${file}`,
        mid: hasMid ? `/photography/mid/${webpName}` : `/photography/${file}`,
      };
    });
}
---

<BaseLayout title="Photography — Abdulla AlBassam">
  <div class="photography-page">
    <div class="film-grain" aria-hidden="true"></div>
    <div class="page-header">
      <div class="title-clip">
        <h1>PHOTOGRAPHY</h1>
      </div>
      <p class="page-desc">Unfiltered, unedited stills. Captured on 35mm film.</p>
      <div class="header-line" aria-hidden="true"></div>
    </div>
    {photos.length > 0 ? (
      <PhotographyGrid client:load photos={photos} />
    ) : (
      <p class="empty-state">No photos yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .photography-page {
    height: 100vh;
    padding: 8rem 0 0;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* --- Film grain overlay --- */
  .film-grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    animation: grain-shift 0.5s steps(4) infinite;
    mix-blend-mode: overlay;
  }

  @keyframes grain-shift {
    0% { transform: translate(0, 0); }
    25% { transform: translate(-2%, -3%); }
    50% { transform: translate(3%, 1%); }
    75% { transform: translate(-1%, 3%); }
    100% { transform: translate(2%, -2%); }
  }

  .page-header {
    text-align: center;
    padding: 0 2rem 3rem;
  }

  /* --- Cinematic title clip reveal --- */
  .title-clip {
    overflow: hidden;
  }

  .page-header h1 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-heading);
    margin: 0;
    animation: clip-reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes clip-reveal {
    from {
      opacity: 0;
      transform: translateY(110%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .page-desc {
    color: var(--text-muted);
    margin-top: 1rem;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    animation: fade-up 0.7s cubic-bezier(0.25, 1, 0.5, 1) 0.25s both;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* --- Decorative header line --- */
  .header-line {
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--text-muted), transparent);
    margin: 2rem auto 0;
    animation: line-draw 1s cubic-bezier(0.25, 1, 0.5, 1) 0.5s both;
    opacity: 0.25;
  }

  @keyframes line-draw {
    from {
      width: 0;
      opacity: 0;
    }
    to {
      width: min(200px, 40vw);
      opacity: 0.25;
    }
  }

  .empty-state {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding-top: 4rem;
  }

  @media (max-width: 768px) {
    .photography-page {
      padding: 7rem 0 0;
    }

    .page-header {
      padding: 0 1.5rem 2rem;
    }
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .page-header h1,
    .page-desc {
      animation: none;
    }

    .header-line {
      animation: none;
      width: min(200px, 40vw);
      opacity: 0.25;
    }

    .film-grain {
      animation: none;
    }
  }
</style>
