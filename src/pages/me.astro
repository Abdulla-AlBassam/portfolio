---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ImageWarp from "@/components/ImageWarp.svelte";
---

<BaseLayout title="Me — Abdulla AlBassam">
  <div class="page">
    <div class="page-header">
      <h1 class="hero-title">ABOUT ME</h1>
    </div>

    <div class="about-layout">
      <div class="about-content">
        <div class="bio">
          <div class="bio-section reveal">
            <h2 class="section-label">BACKGROUND</h2>
            <p>
              I'm Abdulla AlBassam, a final-year Cybersecurity and Networking
              student at <span class="highlight">Northumbria University</span>,
              on track for a <span class="highlight">First Class Honours</span>
              degree. I'm a recipient of the Saudi government's
              <span class="highlight">"Emdad" Scholarship</span> (The Custodian
              of the Two Holy Mosques Scholarship Program), and I hold the
              <span class="highlight">Cisco CCNA</span> and
              <span class="highlight">ISC2 CC</span> certifications, with the
              <span class="highlight">eJPT</span> currently in progress and the
              <span class="highlight">OSCP</span> on my longer-term roadmap.
            </p>
          </div>

          <div class="bio-section collapsible reveal">
            <h2 class="section-label" role="button" tabindex="0" aria-expanded="false">FINAL YEAR PROJECT<span class="chevron" aria-hidden="true"></span></h2>
            <div class="bio-content" aria-hidden="true">
              <p>
                My final year computing project sits at the intersection of
                machine learning and cybersecurity. I am building an adversarially
                robust spam detection system using a fine-tuned
                <span class="highlight">DistilBERT</span> transformer model
                deployed within a secure mail server pipeline, evaluating how
                intelligent systems can be hardened against adversarial
                manipulation. That project represents the kind of work I find most
                compelling, where deep technical problems meet real-world security
                threats.
              </p>
            </div>
          </div>

          <div class="bio-section collapsible reveal">
            <h2 class="section-label" role="button" tabindex="0" aria-expanded="false">EXPERIENCE<span class="chevron" aria-hidden="true"></span></h2>
            <div class="bio-content" aria-hidden="true">
              <p>
                Across my degree, I've worked hands-on in penetration testing,
                defensive security, enterprise networking, digital forensics, and
                secure software architecture. I've conducted vulnerability
                assessments using <span class="highlight">Nmap</span> and
                <span class="highlight">Burp Suite</span>, implemented defensive
                controls with <span class="highlight">iptables</span> and
                <span class="highlight">Snort</span>, designed a multi-site
                enterprise WAN with <span class="highlight">MPLS VPN</span> and
                <span class="highlight">IPSec</span> in
                <span class="highlight">GNS3</span>, carried out forensic
                investigations using <span class="highlight">Autopsy</span>,
                <span class="highlight">FTK Imager</span>, and
                <span class="highlight">Volatility 3</span>, and built a secure
                REST API from scratch. Outside of university, I sharpen my
                offensive skills through CTF challenges on
                <span class="highlight">TryHackMe</span> and
                <span class="highlight">Hack The Box</span>, working through
                real-world exploitation and privilege escalation scenarios.
              </p>
            </div>
          </div>

          <div class="bio-section collapsible reveal">
            <h2 class="section-label" role="button" tabindex="0" aria-expanded="false">SWEATY<span class="chevron" aria-hidden="true"></span></h2>
            <div class="bio-content" aria-hidden="true">
              <p>
                I also build things on the side. I founded
                <span class="highlight">Sweaty</span>, a social platform for
                gamers that I designed and developed end-to-end using
                <span class="highlight">React Native</span>. It features reviews,
                ratings, curated lists, a real-time social feed, AI-powered
                recommendations, and game-library importing. The app is currently
                in pilot testing before its full public release. Teaching myself
                full-stack mobile development, database design, and UI/UX
                principles from scratch to bring a product to life taught me
                invaluable skills in the realm of how business is conducted in the
                real world, and I look forward to further developing my computing
                skills, no matter the niche.
              </p>
            </div>
          </div>

          <div class="bio-section collapsible reveal">
            <h2 class="section-label" role="button" tabindex="0" aria-expanded="false">AI &amp; COMMUNITY<span class="chevron" aria-hidden="true"></span></h2>
            <div class="bio-content" aria-hidden="true">
              <p>
                I'm a member of the <span class="highlight">Claude Builder Club</span>
                at Northumbria, where I work on agentic AI development and
                automation projects. I've also completed certifications from
                <span class="highlight">Anthropic</span> and
                <span class="highlight">Google</span> in AI prototyping and
                agentic development. Whether it's security, software, or AI, I'm
                drawn to building things that work, breaking things that don't,
                and understanding the theory behind both.
              </p>
            </div>
          </div>

          <div class="bio-section reveal">
            <p>
              Contact me <a href="/contact" class="bio-link">here</a>, or find my
              <a href="https://letterboxd.com/3boodi/" class="bio-link">Letterboxd</a> :)
            </p>
          </div>
        </div>

        <div class="education reveal">
          <h2>EDUCATION</h2>
          <div class="edu-card">
            <span class="period">2023 — 2026</span>
            <h3>BSc (Honours) Networks &amp; Cyber Security</h3>
            <p class="institution">Northumbria University, Newcastle</p>
            <p class="institution">Predicted grade: 1st Class Honours</p>
            <p class="description">
              Studying network architecture, ethical hacking, digital forensics,
              and security operations. Hands-on labs in penetration testing and
              incident response.
            </p>
            <div class="modules">
              <span>Network Security</span>
              <span>Ethical Hacking</span>
              <span>Digital Forensics</span>
              <span>Cryptography</span>
              <span>Operating Systems</span>
              <span>Routing &amp; Switching</span>
            </div>
          </div>
          <div class="edu-card">
            <span class="period">2022 — 2023</span>
            <h3>Foundation Year — Economics &amp; Mathematics</h3>
            <p class="institution">King's College London</p>
            <p class="institution">Grade: 2:1</p>
            <p class="description">
              Combined economics and mathematics, covering essential mathematical
              topics for university-level business and economics study. The Economics
              module explored macroeconomics and microeconomics, examining how
              economic and social environments influence government and
              organisational decision-making.
            </p>
            <div class="modules">
              <span>Economics</span>
              <span>Mathematics</span>
              <span>Business &amp; Society</span>
            </div>
          </div>
          <div class="edu-card">
            <span class="period">2008 — 2022</span>
            <h3>American Diploma with Honours</h3>
            <p class="institution">Modern Knowledge Schools, Manama, Bahrain</p>
            <p class="institution">98% Overall GPA</p>
          </div>
        </div>

        <div class="certifications reveal">
          <h2>CERTIFICATIONS</h2>
          <div class="cert-card">
            <h3>INE eJPT: Junior Penetration Tester</h3>
            <p class="issuer">INE Security</p>
            <p class="cert-status">In progress</p>
          </div>
          <div class="cert-card">
            <h3>Cisco CCNA: Enterprise Networking, Security and Automation</h3>
            <p class="issuer">Cisco</p>
          </div>
          <div class="cert-card">
            <h3>ISC2: Certified in Cybersecurity CC</h3>
            <p class="issuer">ISC2</p>
          </div>
          <div class="cert-card">
            <h3>Google: Develop AI-Powered Prototypes in Google AI Studio</h3>
            <p class="issuer">Google</p>
          </div>
        </div>
      </div>

      <div class="photo-area">
        <img src="/aboutme.jpg" alt="Abdulla AlBassam" class="photo" />
        <ImageWarp client:visible />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    padding: 8rem 2rem 4rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    overflow: hidden;
  }

  .hero-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-heading);
    margin: 0 0 3rem 0;
    animation: title-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes title-reveal {
    from {
      opacity: 0;
      transform: translateY(100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: start;
  }

  .bio-section {
    margin-bottom: 2.5rem;
  }

  .section-label {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 0.75rem 0;
    padding-left: 1rem;
    border-left: 2px solid var(--border-active);
    transition: color 0.3s, border-color 0.3s;
  }

  .collapsible .section-label {
    cursor: pointer;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .chevron {
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid var(--text-muted);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    margin-left: auto;
    flex-shrink: 0;
  }

  .collapsible.open .chevron {
    transform: rotate(180deg);
  }

  .collapsible .section-label:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .collapsible.open .section-label {
    margin: 0 0 0.75rem 0;
    border-left-color: var(--text-muted);
  }

  .bio-content {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }

  .collapsible.open .bio-content {
    max-height: 600px;
    opacity: 1;
  }

  .bio-section:hover .section-label {
    color: var(--text-secondary);
    border-left-color: var(--text-muted);
  }

  .bio p {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 0.95rem;
    margin: 0;
  }

  .highlight {
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .highlight:hover {
    color: var(--text-heading);
  }

  .bio-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .bio-link:hover {
    color: var(--text-heading);
  }

  /* Scroll-triggered reveal animations */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .education {
    margin-top: 3rem;
  }

  .education h2 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 1.5rem 0;
  }

  .edu-card {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: border-color 0.3s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s;
  }

  .edu-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .period {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: "Space Grotesk", sans-serif;
    letter-spacing: 0.05em;
  }

  .edu-card h3 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-heading);
    margin: 0.5rem 0 0 0;
  }

  .institution {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 0.25rem 0 0 0;
  }

  .description {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 1rem 0 0 0;
  }

  .modules {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .modules span {
    font-size: 0.7rem;
    padding: 0.25rem 0.75rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
  }

  .certifications {
    margin-top: 3rem;
  }

  .certifications h2 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 1.5rem 0;
  }

  .cert-card {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 1rem;
    transition: border-color 0.3s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s;
  }

  .cert-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .cert-card h3 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-heading);
    margin: 0;
  }

  .cert-card .issuer {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0.25rem 0 0 0;
  }

  .cert-status {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0.35rem 0 0 0;
  }

  .photo-area {
    position: sticky;
    top: 8rem;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
  }

  .photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .page {
      padding: 7rem 1.5rem 3rem;
    }

    .about-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .photo-area {
      order: -1;
      position: static;
    }

    .photo-area {
      max-width: 200px;
      margin: 0 auto;
    }

    .photo {
      aspect-ratio: 1;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = entry.target.dataset.delay || 0;
          setTimeout(() => entry.target.classList.add("visible"), Number(delay));
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll(".reveal").forEach((el, i) => {
    // Stagger bio sections that are in the initial viewport
    const bioSections = el.closest(".bio")
      ? [...document.querySelectorAll(".bio > .reveal")]
      : null;
    if (bioSections) {
      const idx = bioSections.indexOf(el);
      if (idx >= 0) el.dataset.delay = String(idx * 100);
    }
    observer.observe(el);
  });

  document.querySelectorAll(".collapsible .section-label").forEach((label) => {
    function toggle() {
      const section = label.closest(".collapsible");
      const content = section.querySelector(".bio-content");
      const isOpen = section.classList.toggle("open");
      label.setAttribute("aria-expanded", String(isOpen));
      if (content) content.setAttribute("aria-hidden", String(!isOpen));
    }

    label.addEventListener("click", toggle);
    label.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggle();
      }
    });
  });
</script>
