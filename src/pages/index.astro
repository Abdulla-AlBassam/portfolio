---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThreeScene from "@/components/ThreeScene.svelte";
---

<BaseLayout title="Abdulla AlBassam — Cybersecurity & Builder">
  <div class="home">
    <ThreeScene client:idle />
    <div class="hero-text">
      <h1 class="name">
        <span class="line-mask"><span class="line line-1">ABDULLA</span></span>
        <span class="line-mask"><span class="line line-2">ALBASSAM</span></span>
      </h1>
      <p class="subtitle">CYBERSECURITY · MACHINE LEARNING · DEVELOPMENT</p>
    </div>
    <div class="scroll-hint" aria-hidden="true">
      <svg width="20" height="32" viewBox="0 0 20 32" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="1" width="18" height="30" rx="9" />
        <line class="scroll-dot" x1="10" y1="8" x2="10" y2="14" stroke-linecap="round" />
      </svg>
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: var(--bg-primary);
    transition: background 0.4s ease;
  }

  .hero-text {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    text-align: center;
    padding: 1rem;
  }

  .name {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 11vw, 10rem);
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: var(--text-heading);
    display: flex;
    flex-direction: column;
    margin: 0;
    mix-blend-mode: difference;
  }

  .line-mask {
    display: block;
    overflow: hidden;
  }

  .line {
    display: block;
    animation: line-reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .line-1 {
    animation-delay: 0.2s;
  }

  .line-2 {
    animation-delay: 0.4s;
  }

  @keyframes line-reveal {
    from {
      opacity: 0;
      transform: translateY(110%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .subtitle {
    font-family: "Inter", sans-serif;
    font-size: clamp(0.65rem, 1.2vw, 0.95rem);
    letter-spacing: 0.35em;
    color: var(--text-secondary);
    margin-top: 1.5rem;
    font-weight: 300;
    transition: color 0.4s ease;
    opacity: 0;
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    color: var(--text-muted);
    opacity: 0;
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.2s both;
  }

  .scroll-dot {
    animation: scroll-bob 2s ease-in-out infinite;
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(6px); opacity: 0.3; }
  }

  /* Invert Three.js canvas in light mode */
  :global(html.light-mode) .home :global(canvas) {
    filter: invert(1);
    transition: filter 0.4s ease;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .line, .subtitle, .scroll-hint {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .scroll-dot {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .name {
      font-size: clamp(2rem, 10vw, 4rem);
    }

    .subtitle {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
    }

    .scroll-hint {
      bottom: 1.5rem;
    }
  }
</style>
