---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThreeScene from "@/components/ThreeScene.svelte";
---

<BaseLayout title="Abdulla AlBassam — Cybersecurity & Builder">
  <div class="home">
    <ThreeScene client:idle />
    <div class="hero-text">
      <h1 class="name">
        <span class="line">ABDULLA</span>
        <span class="line">ALBASSAM</span>
      </h1>
      <p class="subtitle">CYBERSECURITY · MACHINE LEARNING · DEVELOPMENT</p>
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: var(--bg-primary);
    transition: background 0.4s ease;
  }

  .hero-text {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    text-align: center;
    padding: 1rem;
  }

  .name {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 11vw, 10rem);
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: var(--text-heading);
    display: flex;
    flex-direction: column;
    margin: 0;
    mix-blend-mode: difference;
  }

  .line {
    display: block;
  }

  .subtitle {
    font-family: "Inter", sans-serif;
    font-size: clamp(0.65rem, 1.2vw, 0.95rem);
    letter-spacing: 0.35em;
    color: var(--text-secondary);
    margin-top: 1.5rem;
    font-weight: 300;
    transition: color 0.4s ease;
  }

  /* Invert Three.js canvas in light mode */
  :global(html.light-mode) .home :global(canvas) {
    filter: invert(1);
    transition: filter 0.4s ease;
  }

  @media (max-width: 768px) {
    .name {
      font-size: clamp(2rem, 10vw, 4rem);
    }

    .subtitle {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
    }
  }
</style>
