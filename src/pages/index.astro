---
import MinimalLayout from "@/layouts/MinimalLayout.astro";
---

<MinimalLayout title="Abdulla AlBassam" active="about" sidebarBottom="32rem">
  <img
    slot="sidebar-extra-bottom"
    src="/cartoon.webp"
    alt="Cartoon portrait of Abdulla AlBassam"
    class="sidebar-cartoon"
    width="220"
    height="220"
    loading="eager"
    decoding="async"
  />

  <section class="about">
    <img
      src="/cartoon-about-formal.webp"
      alt="Cartoon portrait of Abdulla AlBassam in traditional Saudi attire"
      class="cartoon cartoon-right"
      width="220"
      height="275"
      loading="eager"
      decoding="async"
    />
    <p>
      I'm a final-year Cybersecurity and Networking student at
      <a href="https://www.northumbria.ac.uk/" target="_blank" rel="noopener noreferrer">Northumbria University</a>,
      on track for First Class Honours and a recipient of the
      <a href="https://sites.moe.gov.sa/scholarship-program/paths/path-emdad/" target="_blank" rel="noopener noreferrer">Emdad</a> Scholarship.
    </p>

    <p>
      My recently completed dissertation built a
      <button type="button" class="link-button strong-link" data-modal-trigger="email-server">hardened email system with a cascading AI filter</button>,
      sharpening my interest in agentic and autonomous AI, and how they will
      reshape both sides of the cyber arms race.
    </p>

    <p>
      I'm also building <a href="https://sweatyapp.com" target="_blank" rel="noopener noreferrer">Sweaty</a>,
      a social platform for gamers.
    </p>

    <p>
      Recently, my team and I took home the Innovation Award at Northumbria's
      <button type="button" class="link-button" data-modal-trigger="hackathon">Anthropic × Accenture Hackathon</button>,
      where we built a digital solution to a problem affecting the people of the UK.
    </p>

    <p>
      On the offensive, I specialise in web and SQL exploitation, and I'm
      currently working toward the
      <a href="https://security.ine.com/certifications/ejpt-certification/" target="_blank" rel="noopener noreferrer">eJPT</a>
      certification. On the defensive, I have hands-on experience in
      intrusion detection, network hardening, and digital forensics.
    </p>

    <h2 class="block-heading">Education</h2>
    <ul class="entries">
      <li>
        <div class="entry-row">
          <div>
            <strong>BSc (Hons) Networks &amp; Cyber Security</strong>
            <span class="muted"> · Northumbria University</span>
          </div>
          <span class="meta">2023 — 2026</span>
        </div>
        <p class="muted small">Predicted: First Class Honours.</p>
      </li>
      <li>
        <div class="entry-row">
          <div>
            <strong>Foundation Year: Economics &amp; Mathematics</strong>
            <span class="muted"> · King's College London</span>
          </div>
          <span class="meta">2022 — 2023</span>
        </div>
        <p class="muted small">Grade: 2:1.</p>
      </li>
      <li>
        <div class="entry-row">
          <div>
            <strong>American Diploma with Honours</strong>
            <span class="muted"> · Modern Knowledge Schools, Bahrain</span>
          </div>
          <span class="meta">2008 — 2022</span>
        </div>
        <p class="muted small">Grade: 98%</p>
      </li>
    </ul>
  </section>

  <dialog class="link-modal" id="email-server-modal" aria-labelledby="email-server-modal-title">
    <button type="button" class="modal-close" aria-label="Close" data-modal-close>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <p class="modal-eyebrow">View project</p>
    <h3 class="modal-title" id="email-server-modal-title">Local Email Server with a Cascade AI Spam Filter</h3>
    <p class="modal-sub">Dissertation project: hardened SMTP/IMAP stack with multi-stage AI filtering</p>
    <div class="modal-actions">
      <a href="/projects/docs/dissertation.pdf" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
        </svg>
        <span class="label">Thesis</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a href="https://github.com/Abdulla-AlBassam" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-1.97c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z" />
        </svg>
        <span class="label">GitHub</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </dialog>

  <dialog class="link-modal" id="hackathon-modal" aria-labelledby="hackathon-modal-title">
    <button type="button" class="modal-close" aria-label="Close" data-modal-close>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <p class="modal-eyebrow">View project</p>
    <h3 class="modal-title" id="hackathon-modal-title">Lean-in</h3>
    <p class="modal-sub">Anthropic × Accenture Hackathon · Innovation Award</p>
    <div class="modal-actions">
      <a href="https://github.com/Abdulla-AlBassam/lean-in" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-1.97c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z" />
        </svg>
        <span class="label">GitHub</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a href="https://www.linkedin.com/feed/update/urn:li:activity:7459351820537274368/" target="_blank" rel="noopener noreferrer" class="modal-btn">
        <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
        </svg>
        <span class="label">LinkedIn</span>
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </dialog>

  <script>
    document.querySelectorAll<HTMLElement>('[data-modal-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-modal-trigger');
        const dialog = document.getElementById(`${id}-modal`) as HTMLDialogElement | null;
        dialog?.showModal();
      });
    });

    document.querySelectorAll<HTMLDialogElement>('dialog.link-modal').forEach((dialog) => {
      dialog.querySelector<HTMLButtonElement>('[data-modal-close]')?.addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
      });
    });
  </script>
</MinimalLayout>

<style>
  .about {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
    position: relative;
  }

  .cartoon-right {
    position: absolute;
    top: -0.5rem;
    left: 100%;
    margin-left: 2rem;
    width: 220px;
    height: auto;
    pointer-events: none;
    user-select: none;
  }

  @media (max-width: 1080px) {
    .cartoon-right {
      display: none;
    }
  }

  .about strong {
    color: var(--ink);
    font-weight: 600;
  }

  .about em {
    color: var(--ink);
    font-style: normal;
    font-weight: 500;
  }

  .block-heading {
    font-family: "Montserrat", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 2.5rem 0 1rem;
  }

  .entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .entries > li {
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .entries > li:last-child {
    border-bottom: none;
  }

  .entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .entry-row strong {
    color: var(--ink);
    font-weight: 600;
  }

  .meta {
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--cloudy-deep);
    white-space: nowrap;
  }

  .muted {
    color: var(--cloudy-deep);
  }

  .small {
    font-size: 0.8rem;
    margin: 0.3rem 0 0;
  }

  .link-button {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: var(--crail);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .link-button:hover {
    color: var(--crail-soft);
  }

  .link-button:focus-visible {
    outline: 2px solid var(--crail);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .link-button.strong-link {
    color: var(--crail);
    font-weight: 600;
  }

  .link-button.strong-link:hover {
    color: var(--crail-soft);
  }

  .link-modal {
    background: var(--pampas);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1.75rem 1.75rem 1.5rem;
    width: min(92vw, 360px);
    box-shadow: 0 30px 80px rgba(20, 18, 16, 0.28), 0 2px 8px rgba(20, 18, 16, 0.08);
    position: relative;
    font-family: "Montserrat", sans-serif;
  }

  .link-modal::backdrop {
    background: rgba(26, 24, 22, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .link-modal[open] {
    animation: modal-in 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .link-modal[open]::backdrop {
    animation: backdrop-in 0.2s ease-out;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.96) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .modal-close {
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--cloudy-deep);
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .modal-close:hover {
    color: var(--ink);
    background: var(--pampas-deep);
  }

  .modal-eyebrow {
    font-family: "Montserrat", sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 0 0 0.55rem;
  }

  .modal-title {
    font-family: "Montserrat", sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
    color: var(--ink);
  }

  .modal-sub {
    font-size: 0.78rem;
    color: var(--cloudy-deep);
    margin: 0 0 1.25rem;
  }

  .modal-actions {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .modal-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.95rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    color: var(--ink);
    text-decoration: none;
    font-family: "Montserrat", sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    background: transparent;
    transition: 0.18s ease;
  }

  .modal-btn .icon,
  .modal-btn .arrow {
    flex-shrink: 0;
    color: var(--ink-soft);
    transition: color 0.18s ease, transform 0.18s ease;
  }

  .modal-btn .label {
    flex: 1;
  }

  .modal-btn .arrow {
    color: var(--cloudy-deep);
  }

  .modal-btn:hover {
    background: var(--crail);
    color: var(--pampas);
    border-color: var(--crail);
  }

  .modal-btn:hover .icon,
  .modal-btn:hover .arrow {
    color: var(--pampas);
  }

  .modal-btn:hover .arrow {
    transform: translateX(3px);
  }

  .modal-btn:focus-visible {
    outline: 2px solid var(--crail);
    outline-offset: 2px;
  }
</style>
