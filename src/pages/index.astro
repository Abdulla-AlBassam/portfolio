---
import MinimalLayout from "@/layouts/MinimalLayout.astro";
import LinkModal from "@/components/LinkModal.astro";
---

<MinimalLayout title="Abdulla AlBassam's Portfolio" active="about" sidebarBottom="32rem">
  <img
    slot="sidebar-extra-bottom"
    src="/cartoon.webp"
    alt="Cartoon portrait of Abdulla AlBassam"
    class="sidebar-cartoon"
    width="220"
    height="220"
    loading="eager"
    decoding="async"
  />

  <section class="about">
    <img
      src="/cartoon-about-formal.webp"
      alt="Cartoon portrait of Abdulla AlBassam in traditional Saudi attire"
      class="cartoon cartoon-right"
      width="220"
      height="275"
      loading="eager"
      decoding="async"
    />
    <p>
      I'm a final-year Cybersecurity and Networking student at
      <a href="https://www.northumbria.ac.uk/" target="_blank" rel="noopener noreferrer">Northumbria University</a>,
      on track for First Class Honours and a recipient of the
      <a href="https://sites.moe.gov.sa/scholarship-program/paths/path-emdad/" target="_blank" rel="noopener noreferrer">Emdad</a> Scholarship.
    </p>

    <p>
      I'm engineering agentic security tools and researching how autonomous AI
      will reshape both sides of the cyber arms race.
    </p>

    <p>
      I'm also building <a href="https://sweatyapp.com" target="_blank" rel="noopener noreferrer">Sweaty</a>,
      a social platform for gamers.
    </p>

    <p>
      Recently, my team and I took home the Innovation Award at Northumbria's
      <button type="button" class="link-button" data-modal-trigger="hackathon">Anthropic × Accenture Hackathon</button>,
      where we built a digital solution to a problem affecting the people of the UK.
    </p>

    <h2 class="block-heading">Education</h2>
    <ul class="entries">
      <li>
        <div class="entry-row">
          <div>
            <strong>BSc (Hons) Networks &amp; Cyber Security</strong>
            <span class="muted institution">Northumbria University</span>
          </div>
          <span class="meta">2023 – 2026</span>
        </div>
        <p class="muted small">Predicted: First Class Honours.</p>
      </li>
      <li>
        <div class="entry-row">
          <div>
            <strong>Foundation Year: Economics &amp; Mathematics</strong>
            <span class="muted institution">King's College London</span>
          </div>
          <span class="meta">2022 – 2023</span>
        </div>
        <p class="muted small">Grade: 2:1.</p>
      </li>
      <li>
        <div class="entry-row">
          <div>
            <strong>American Diploma with Honours</strong>
            <span class="muted institution">Modern Knowledge Schools, Bahrain</span>
          </div>
          <span class="meta">2008 – 2022</span>
        </div>
        <p class="muted small">Grade: 98%</p>
      </li>
    </ul>
  </section>

  <LinkModal
    id="hackathon"
    eyebrow="View project"
    title="Lean-in"
    subtitle="Anthropic × Accenture Hackathon · Innovation Award"
    links={[
      { label: "GitHub", href: "https://github.com/Abdulla-AlBassam/lean-in", icon: "github" },
      { label: "LinkedIn", href: "https://www.linkedin.com/feed/update/urn:li:activity:7459351820537274368/", icon: "linkedin" },
    ]}
    cert={{
      src: "/certs/hackathon.webp",
      alt: "Certificate of Achievement – Accenture Award for Innovation, Anthropic × Accenture Hackathon, Northumbria University, May 2026",
    }}
  />
</MinimalLayout>

<style>
  .about {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
    position: relative;
  }

  .cartoon-right {
    position: absolute;
    top: -0.5rem;
    left: 100%;
    margin-left: 2rem;
    width: 220px;
    height: auto;
    pointer-events: none;
    user-select: none;
  }

  @media (max-width: 1080px) {
    .cartoon-right {
      display: none;
    }
  }

  .about strong {
    color: var(--ink);
    font-weight: 600;
  }

  .about em {
    color: var(--ink);
    font-style: normal;
    font-weight: 500;
  }

  .block-heading {
    font-family: "Montserrat", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 1rem 0 1rem;
  }

  .entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .entries > li {
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .entries > li:last-child {
    border-bottom: none;
  }

  .entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .entry-row strong {
    color: var(--ink);
    font-weight: 600;
  }

  .meta {
    font-family: "Montserrat", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--cloudy-deep);
    white-space: nowrap;
  }

  .muted {
    color: var(--cloudy-deep);
  }

  .institution {
    display: block;
    margin-top: 0.15rem;
  }

  .small {
    font-size: 0.8rem;
    margin: 0.3rem 0 0;
  }
</style>
