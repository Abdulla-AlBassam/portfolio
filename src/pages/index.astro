---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThreeScene from "@/components/ThreeScene.svelte";
---

<BaseLayout title="Abdulla AlBassam — Cybersecurity & Builder">
  <div class="home">
    <ThreeScene client:idle />
    <div class="hero-text">
      <h1 class="name">
        <span class="line">ABDULLA</span>
        <span class="line">ALBASSAM</span>
      </h1>
      <p class="subtitle">CYBERSECURITY · MACHINE LEARNING · DEVELOPMENT</p>
    </div>
  </div>

  <!-- Theme toggle (homepage only) -->
  <button
    class="theme-toggle"
    id="theme-toggle"
    aria-label="Toggle light mode"
    type="button"
  >
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </svg>
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>
</BaseLayout>

<style>
  .home {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: var(--bg-primary);
    transition: background 0.4s ease;
  }

  .hero-text {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    text-align: center;
    padding: 1rem;
  }

  .name {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 11vw, 10rem);
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: var(--text-heading);
    display: flex;
    flex-direction: column;
    margin: 0;
    mix-blend-mode: difference;
  }

  .line {
    display: block;
  }

  .subtitle {
    font-family: "Inter", sans-serif;
    font-size: clamp(0.65rem, 1.2vw, 0.95rem);
    letter-spacing: 0.35em;
    color: var(--text-secondary);
    margin-top: 1.5rem;
    font-weight: 300;
    transition: color 0.4s ease;
  }

  /* ── Theme toggle ── */
  .theme-toggle {
    position: fixed;
    top: 1.65rem;
    right: 5.5rem;
    z-index: 50;
    background: none;
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-muted);
    transition: color 0.3s, border-color 0.3s;
  }

  .theme-toggle:hover {
    color: var(--text-heading);
    border-color: var(--border-hover);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Show sun in dark mode, moon in light mode */
  .icon-moon { display: none; }
  .icon-sun { display: block; }

  :global(html.light-mode) .icon-sun { display: none; }
  :global(html.light-mode) .icon-moon { display: block; }

  /* ── Invert Three.js canvas in light mode ── */
  :global(html.light-mode) .home :global(canvas) {
    filter: invert(1);
    transition: filter 0.4s ease;
  }

  @media (max-width: 768px) {
    .name {
      font-size: clamp(2rem, 10vw, 4rem);
    }

    .subtitle {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
    }

    .theme-toggle {
      right: 4.5rem;
      top: 1.35rem;
      width: 34px;
      height: 34px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const key = 'theme-preference';

  // Restore saved preference
  const saved = localStorage.getItem(key);
  if (saved === 'light') {
    html.classList.add('light-mode');
  }

  toggle?.addEventListener('click', () => {
    const isLight = html.classList.toggle('light-mode');
    localStorage.setItem(key, isLight ? 'light' : 'dark');
    toggle.setAttribute('aria-label', isLight ? 'Toggle dark mode' : 'Toggle light mode');
  });
</script>
