---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Skills — Abdulla AlBassam">
  <div class="page">
    <div class="page-header">
      <h1>SKILLS</h1>
      <p class="page-desc">
        A blend of cybersecurity, networking, and development — built through
        hands-on projects.
      </p>
    </div>

    <div class="skills-grid">
      <div class="skill-category featured">
        <div class="category-header">
          <span class="category-number">01</span>
          <h2>Cybersecurity</h2>
        </div>
        <div class="skill-tags">
          <span>Penetration Testing</span>
          <span>Threat Modeling</span>
          <span>Network Security</span>
          <span>OSINT</span>
          <span>Snort</span>
          <span>iptables</span>
          <span>Hydra</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <span class="category-number">02</span>
          <h2>Networking</h2>
        </div>
        <div class="skill-tags">
          <span>CCNA</span>
          <span>OSPF</span>
          <span>VPNs</span>
          <span>ACLs</span>
          <span>MPLS</span>
          <span>Cisco Packet Tracer</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <span class="category-number">03</span>
          <h2>Development</h2>
        </div>
        <div class="skill-tags">
          <span>Next.js</span>
          <span>Python</span>
          <span>PHP</span>
          <span>JavaScript/TypeScript</span>
          <span>SQL</span>
          <span>HTML</span>
          <span>Tailwind CSS</span>
          <span>Supabase</span>
          <span>Git</span>
          <span>Docker</span>
          <span>Postman</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <span class="category-number">04</span>
          <h2>Tools</h2>
        </div>
        <div class="skill-tags">
          <span>Burp Suite</span>
          <span>Nmap</span>
          <span>Metasploit</span>
          <span>GNS3</span>
          <span>Wireshark</span>
          <span>Figma</span>
          <span>UTM</span>
          <span>Autopsy</span>
          <span>FTK Imager</span>
          <span>Volatility 3</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <span class="category-number">05</span>
          <h2>Machine Learning</h2>
        </div>
        <div class="skill-tags">
          <span>Jupyter</span>
          <span>pandas</span>
          <span>NumPy</span>
          <span>scikit-learn</span>
          <span>PyTorch</span>
          <span>Transformers</span>
          <span>TextAttack</span>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    padding: 8rem 2rem 4rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
  }

  .page-header h1 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-heading);
    margin: 0;
  }

  .page-desc {
    color: var(--text-muted);
    margin-top: 1rem;
    font-size: 0.95rem;
    margin-bottom: 4rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  /* --- Card base --- */
  .skill-category {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 2rem;
    transition:
      border-color 0.3s,
      background 0.3s;
  }

  .skill-category:hover {
    border-color: var(--border-hover);
    background: var(--bg-hover);
  }

  /* --- Featured cards span full width --- */
  .skill-category.featured {
    grid-column: 1 / -1;
    border-color: var(--border-hover);
    padding: 2.5rem;
  }

  .skill-category.featured:hover {
    border-color: var(--border-active);
  }

  /* --- Category header --- */
  .category-header {
    margin-bottom: 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
  }

  .category-number {
    font-family: "Space Grotesk", sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text-heading);
    opacity: 0.15;
    transition: opacity 0.3s;
  }

  .skill-category:hover .category-number {
    opacity: 0.25;
  }

  .featured .category-number {
    font-size: 3.5rem;
    opacity: 0.2;
  }

  .skill-category.featured:hover .category-number {
    opacity: 0.3;
  }

  .category-header h2 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-heading);
    margin: 0;
  }

  .featured .category-header h2 {
    font-size: 2rem;
  }

  /* --- Tags --- */
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tags span {
    font-size: 0.8rem;
    padding: 0.4rem 1rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
    transition:
      color 0.2s,
      border-color 0.2s,
      background 0.2s;
  }

  .skill-tags span:hover {
    color: var(--text-heading);
    border-color: var(--border-active);
    background: var(--bg-subtle-hover);
  }

  .featured .skill-tags span {
    padding: 0.5rem 1.15rem;
    font-size: 0.85rem;
  }

  /* --- Mobile --- */
  @media (max-width: 768px) {
    .page {
      padding: 7rem 1.5rem 3rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-category.featured {
      padding: 2rem;
    }

    .category-number {
      font-size: 2rem;
    }

    .featured .category-number {
      font-size: 2.5rem;
    }

    .featured .category-header h2 {
      font-size: 1.5rem;
    }
  }
</style>
