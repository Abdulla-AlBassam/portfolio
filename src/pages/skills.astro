---
import MinimalLayout from "@/layouts/MinimalLayout.astro";

const groups = [
  {
    name: "Cybersecurity",
    items: ["Penetration Testing", "Threat Modeling", "Network Security", "OSINT", "Snort", "iptables", "Hydra", "Burp Suite", "Nmap", "Metasploit", "Autopsy", "FTK Imager", "Volatility 3"],
  },
  {
    name: "Networking",
    items: ["OSPF", "VPNs", "ACLs", "MPLS", "VLSM", "SMTP", "BIND9", "Cisco Packet Tracer", "GNS3", "Wireshark"],
  },
  {
    name: "Languages",
    items: ["Python", "JavaScript / TypeScript", "PHP", "C", "SQL", "HTML"],
  },
  {
    name: "Frameworks",
    items: ["Next.js", "React Native", "Astro", "Svelte", "Three.js", "Tailwind CSS", "Flask", "FastAPI"],
  },
  {
    name: "Databases",
    items: ["PostgreSQL", "SQLite", "Supabase"],
  },
  {
    name: "Operating Systems",
    items: ["Linux", "Ubuntu", "macOS", "Windows"],
  },
  {
    name: "DevOps",
    items: ["Git / GitHub", "Docker", "Virtual Machines", "Apache", "Vercel", "Figma"],
  },
  {
    name: "Machine Learning",
    items: ["Jupyter", "Google Colab", "pandas", "NumPy", "scikit-learn", "PyTorch", "Transformers"],
  },
];

interface Cert {
  name: string;
  issuer: string;
  status?: string;
  href?: string;
}

const linkedInCerts = "https://www.linkedin.com/in/abdulla-albassam/details/certifications/";

const certs: Cert[] = [
  { name: "INE eJPT — Junior Penetration Tester", issuer: "INE Security", status: "In progress" },
  { name: "Cisco CCNA — Enterprise Networking, Security and Automation", issuer: "Cisco", href: linkedInCerts },
  { name: "ISC2 CC — Certified in Cybersecurity", issuer: "ISC2", href: linkedInCerts },
  { name: "Develop AI-Powered Prototypes in Google AI Studio", issuer: "Google", href: linkedInCerts },
  { name: "Anthropic AI Fluency Courses", issuer: "Anthropic", href: "https://anthropic.skilljar.com/" },
];
---

<MinimalLayout title="Skills & Certs — Abdulla AlBassam" active="skills">
  <section class="skills">
    <h2 class="block-heading">Certifications</h2>
    <ul class="cert-list">
      {
        certs.map((c) => {
          const Tag = c.href ? "a" : "div";
          const linkProps = c.href ? { href: c.href, target: "_blank", rel: "noopener noreferrer" } : {};
          return (
            <li>
              <Tag class="cert-row" {...linkProps}>
                <div>
                  <strong>{c.name}</strong>
                  <span class="muted"> · {c.issuer}</span>
                </div>
                {c.status && <span class="cert-status">{c.status}</span>}
                {c.href && !c.status && (
                  <span class="cert-arrow" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="7" y1="17" x2="17" y2="7" />
                      <polyline points="7 7 17 7 17 17" />
                    </svg>
                  </span>
                )}
              </Tag>
            </li>
          );
        })
      }
    </ul>

    {
      groups.map((g, i) => (
        <div class:list={["group", { "first-group": i === 0 }]}>
          <h2 class="block-heading">{g.name}</h2>
          <ul class="tags">
            {g.items.map((s) => (
              <li>{s}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>
</MinimalLayout>

<style>
  .skills {
    color: var(--ink-soft);
    position: relative;
  }

  .lede {
    color: var(--cloudy-deep);
    font-size: 0.88rem;
    margin-bottom: 2rem;
  }

  .group {
    margin-bottom: 2rem;
  }

  .group.first-group {
    margin-top: 2.5rem;
  }

  .block-heading {
    font-family: "Montserrat", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 0 0 0.85rem;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--ink);
    background: var(--pampas-deep);
    border: 1px solid var(--rule);
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .tags li:hover {
    border-color: var(--cloudy);
  }

  .cert-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cert-list > li {
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .cert-list > li:last-child {
    border-bottom: none;
  }

  .cert-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a.cert-row:hover {
    color: var(--crail);
  }

  a.cert-row:hover strong {
    color: var(--crail);
  }

  .cert-row strong {
    color: var(--ink);
    font-weight: 600;
    transition: color 0.15s ease;
  }

  .cert-arrow {
    color: var(--cloudy-deep);
    display: inline-flex;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  a.cert-row:hover .cert-arrow {
    color: var(--crail);
    transform: translate(2px, -2px);
  }

  .muted {
    color: var(--cloudy-deep);
  }

  .cert-status {
    font-family: "Montserrat", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--crail);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
