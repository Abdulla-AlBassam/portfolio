---
import MinimalLayout from "@/layouts/MinimalLayout.astro";

const groups = [
  {
    name: "Cybersecurity",
    items: [
      "Penetration Testing",
      "Threat Modeling",
      "Network Security",
      "OSINT",
      "Snort",
      "iptables",
      "Hydra",
      "Burp Suite",
      "Nmap",
      "Metasploit",
      "Autopsy",
      "FTK Imager",
      "Volatility 3",
    ],
  },
  {
    name: "Networking",
    items: [
      "OSPF",
      "VPNs",
      "ACLs",
      "MPLS",
      "Cisco Packet Tracer",
      "GNS3",
      "Wireshark",
      "UTM",
    ],
  },
  {
    name: "Development",
    items: [
      "Next.js",
      "React Native",
      "Python",
      "PHP",
      "JavaScript / TypeScript",
      "SQL",
      "HTML",
      "Tailwind CSS",
      "Supabase",
      "Git",
      "Docker",
      "Postman",
      "Figma",
    ],
  },
  {
    name: "Machine Learning",
    items: [
      "Jupyter",
      "pandas",
      "NumPy",
      "scikit-learn",
      "PyTorch",
      "Transformers",
      "TextAttack",
    ],
  },
];

const certs = [
  { name: "INE eJPT — Junior Penetration Tester", issuer: "INE Security", status: "In progress" },
  { name: "Cisco CCNA — Enterprise Networking, Security and Automation", issuer: "Cisco" },
  { name: "ISC2 CC — Certified in Cybersecurity", issuer: "ISC2" },
  { name: "Develop AI-Powered Prototypes in Google AI Studio", issuer: "Google" },
];
---

<MinimalLayout title="Skills & Certs — Abdulla Al Bassam" active="skills">
  <section class="skills">
    <p class="lede">
      A blend of cybersecurity, networking, machine learning, and software
      engineering — built through degree work, certifications, and personal
      projects.
    </p>

    {
      groups.map((g) => (
        <div class="group">
          <h2 class="block-heading">{g.name}</h2>
          <ul class="tags">
            {g.items.map((s) => (
              <li>{s}</li>
            ))}
          </ul>
        </div>
      ))
    }

    <h2 class="block-heading certs-heading">Certifications</h2>
    <ul class="cert-list">
      {
        certs.map((c) => (
          <li>
            <div class="cert-row">
              <div>
                <strong>{c.name}</strong>
                <span class="muted"> · {c.issuer}</span>
              </div>
              {c.status && <span class="cert-status">{c.status}</span>}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</MinimalLayout>

<style>
  .skills {
    color: var(--ink-soft);
  }

  .lede {
    color: var(--cloudy-deep);
    font-size: 0.88rem;
    margin-bottom: 2rem;
  }

  .group {
    margin-bottom: 2rem;
  }

  .block-heading {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cloudy-deep);
    margin: 0 0 0.85rem;
  }

  .certs-heading {
    margin-top: 2.5rem;
    margin-bottom: 0.85rem;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--ink);
    background: var(--pampas-deep);
    border: 1px solid var(--rule);
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .tags li:hover {
    border-color: var(--cloudy);
  }

  .cert-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cert-list > li {
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .cert-list > li:last-child {
    border-bottom: none;
  }

  .cert-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .cert-row strong {
    color: var(--ink);
    font-weight: 600;
  }

  .muted {
    color: var(--cloudy-deep);
  }

  .cert-status {
    font-family: "JetBrains Mono", "SF Mono", monospace;
    font-size: 0.68rem;
    color: var(--crail);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
