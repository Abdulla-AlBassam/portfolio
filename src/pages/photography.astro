---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotographyGrid from "@/components/PhotographyGrid.svelte";

const photographyDir = path.join(process.cwd(), "public", "photography");
const thumbDir = path.join(photographyDir, "thumbs");
const validExtensions = new Set([".jpg", ".jpeg", ".png", ".webp", ".avif", ".gif"]);

let photos: { src: string; thumb: string }[] = [];

if (fs.existsSync(photographyDir)) {
  const hasThumbDir = fs.existsSync(thumbDir);
  const thumbFiles = hasThumbDir ? new Set(fs.readdirSync(thumbDir)) : new Set<string>();

  photos = fs
    .readdirSync(photographyDir)
    .filter((file) => {
      const ext = path.extname(file).toLowerCase();
      return validExtensions.has(ext) && !file.startsWith(".");
    })
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
    .map((file) => {
      const thumbName = file.replace(/\.\w+$/, ".webp");
      const hasThumb = thumbFiles.has(thumbName);
      return {
        src: `/photography/${file}`,
        thumb: hasThumb ? `/photography/thumbs/${thumbName}` : `/photography/${file}`,
      };
    });
}
---

<BaseLayout title="Photography — Abdulla AlBassam">
  <div class="photography-page">
    <p class="photography-description">Unfiltered, unedited stills. Captured on 35mm Film.</p>
    {photos.length > 0 ? (
      <PhotographyGrid client:load photos={photos} />
    ) : (
      <p class="empty-state">No photos yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .photography-page {
    min-height: 100vh;
    padding: 5rem 0.5rem 2rem;
  }

  .photography-description {
    text-align: center;
    color: #888;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .empty-state {
    text-align: center;
    color: #555;
    font-size: 0.9rem;
    padding-top: 4rem;
  }
</style>
