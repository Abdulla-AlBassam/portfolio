---
import MinimalLayout from "@/layouts/MinimalLayout.astro";
import fs from "node:fs";
import path from "node:path";

const photoDir = path.join(process.cwd(), "public", "photography");
const thumbDir = path.join(photoDir, "thumbs");
const midDir = path.join(photoDir, "mid");

const supported = /\.(jpe?g|png|tif|tiff|webp)$/i;
const files = fs
  .readdirSync(photoDir, { withFileTypes: true })
  .filter((d) => d.isFile() && supported.test(d.name))
  .map((d) => d.name)
  .sort();

const hasThumbs = fs.existsSync(thumbDir);
const hasMid = fs.existsSync(midDir);

const thumbsAvailable = new Set(
  hasThumbs ? fs.readdirSync(thumbDir).filter((f) => /\.webp$/i.test(f)) : []
);
const midAvailable = new Set(
  hasMid ? fs.readdirSync(midDir).filter((f) => /\.webp$/i.test(f)) : []
);

const photos = files.map((name) => {
  const base = name.replace(/\.[^.]+$/, "");
  const webpName = `${base}.webp`;
  const thumb = thumbsAvailable.has(webpName)
    ? `/photography/thumbs/${webpName}`
    : `/photography/${name}`;
  const full = midAvailable.has(webpName)
    ? `/photography/mid/${webpName}`
    : `/photography/${name}`;
  return { thumb, full, name };
});
---

<MinimalLayout title="Photography — Abdulla Al Bassam" active="photography">
  <section class="photography">
    <p class="lede">
      A selection of frames I've taken on film and digital, mostly while
      travelling. Click any image to view it full-size.
    </p>

    <div class="grid">
      {
        photos.map((p, i) => (
          <button
            class="cell"
            type="button"
            data-index={i}
            data-full={p.full}
            aria-label={`Open photo ${i + 1} of ${photos.length}`}
          >
            <img
              src={p.thumb}
              alt=""
              loading="lazy"
              decoding="async"
              width="400"
              height="400"
            />
          </button>
        ))
      }
    </div>
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Photo viewer">
    <button class="lb-close" type="button" aria-label="Close (Esc)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <button class="lb-nav lb-prev" type="button" aria-label="Previous photo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
    </button>
    <img class="lb-img" alt="" />
    <button class="lb-nav lb-next" type="button" aria-label="Next photo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </button>
    <div class="lb-counter" aria-live="polite"></div>
  </div>
</MinimalLayout>

<script>
  const cells = Array.from(document.querySelectorAll<HTMLButtonElement>(".cell"));
  const lb = document.getElementById("lightbox") as HTMLDivElement;
  const lbImg = lb.querySelector<HTMLImageElement>(".lb-img")!;
  const lbCounter = lb.querySelector<HTMLDivElement>(".lb-counter")!;
  const closeBtn = lb.querySelector<HTMLButtonElement>(".lb-close")!;
  const prevBtn = lb.querySelector<HTMLButtonElement>(".lb-prev")!;
  const nextBtn = lb.querySelector<HTMLButtonElement>(".lb-next")!;

  let current = 0;
  const sources = cells.map((c) => c.dataset.full || "");

  function open(index: number) {
    current = index;
    show();
    lb.setAttribute("aria-hidden", "false");
    lb.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function close() {
    lb.setAttribute("aria-hidden", "true");
    lb.classList.remove("open");
    document.body.style.overflow = "";
  }

  function show() {
    lbImg.src = sources[current];
    lbCounter.textContent = `${current + 1} / ${sources.length}`;
  }

  function step(delta: number) {
    current = (current + delta + sources.length) % sources.length;
    show();
  }

  cells.forEach((cell, i) => cell.addEventListener("click", () => open(i)));
  closeBtn.addEventListener("click", close);
  prevBtn.addEventListener("click", () => step(-1));
  nextBtn.addEventListener("click", () => step(1));

  lb.addEventListener("click", (e) => {
    if (e.target === lb) close();
  });

  document.addEventListener("keydown", (e) => {
    if (lb.getAttribute("aria-hidden") === "true") return;
    if (e.key === "Escape") close();
    else if (e.key === "ArrowLeft") step(-1);
    else if (e.key === "ArrowRight") step(1);
  });
</script>

<style>
  .photography {
    color: var(--ink-soft);
  }

  .lede {
    color: var(--cloudy-deep);
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 3px;
  }

  .cell {
    all: unset;
    cursor: zoom-in;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--pampas-deep);
    border-radius: 2px;
    display: block;
  }

  .cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease, opacity 0.2s ease;
  }

  .cell:hover img {
    transform: scale(1.04);
  }

  .cell:focus-visible {
    outline: 2px solid var(--crail);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(26, 24, 22, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }

  .lightbox.open {
    display: flex;
  }

  .lb-img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    box-shadow: 0 12px 60px rgba(0, 0, 0, 0.5);
  }

  .lb-close,
  .lb-nav {
    position: absolute;
    background: rgba(244, 243, 238, 0.1);
    border: 1px solid rgba(244, 243, 238, 0.2);
    color: var(--pampas);
    padding: 0.6rem;
    border-radius: 50%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .lb-close:hover,
  .lb-nav:hover {
    background: rgba(244, 243, 238, 0.2);
    border-color: rgba(244, 243, 238, 0.4);
  }

  .lb-close {
    top: 1.25rem;
    right: 1.25rem;
  }

  .lb-prev {
    left: 1.5rem;
  }

  .lb-next {
    right: 1.5rem;
  }

  .lb-counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: "JetBrains Mono", "SF Mono", monospace;
    font-size: 0.78rem;
    color: rgba(244, 243, 238, 0.7);
  }

  @media (max-width: 600px) {
    .lb-prev {
      left: 0.75rem;
    }
    .lb-next {
      right: 0.75rem;
    }
  }
</style>
